#!/usr/bin/bash
# Terra's steamos-session-select execs this hook (Steam "Switch to Desktop").
set -euo pipefail

case "${1:-gamescope}" in
    desktop|niri) exec sudo /usr/libexec/armada/session-control switch-desktop ;;
    gamescope)      exec sudo /usr/libexec/armada/session-control switch-gamemode ;;
    *) echo "unrecognised session: ${1}" >&2; exit 1 ;;
esac

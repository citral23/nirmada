#!/bin/bash
# Rebuild the ESP /KERNEL (Android boot.img) for the next-boot deployment so a
# bootc upgrade/rollback takes effect — ostree is bootloader=none and won't.
set -euo pipefail

ESP="${ESP:-/boot/efi}"
BOOTROOT="${BOOTROOT:-/boot}"
MKBOOTIMG="${MKBOOTIMG:-/usr/libexec/armada/mkbootimg.py}"
DTB_LIST="${DTB_LIST:-/usr/lib/armada/supported-dtbs}"
ARGS_FILE="${ARGS_FILE:-/usr/lib/armada/bootimg-args}"
KERNEL_OUT="${ESP}/KERNEL"
STAMP="${ESP}/.armada-bootimg.id"

[ -r "${DTB_LIST}" ] || { echo "armada-bootimg-update: missing ${DTB_LIST}" >&2; exit 1; }
[ -r "${ARGS_FILE}" ] || { echo "armada-bootimg-update: missing ${ARGS_FILE}" >&2; exit 1; }
. "${ARGS_FILE}"

# /KERNEL must land on the FAT ESP the ABL reads; if it isn't mounted we'd write
# to a stray dir and the ABL would keep booting the old kernel. Fail loud instead.
findmnt -rn "${ESP}" >/dev/null 2>&1 || {
    echo "armada-bootimg-update: ${ESP} is not a mountpoint; refusing to write /KERNEL" >&2
    exit 1
}

# Next-boot deployment = highest-version BLS entry; ostree assigns its default
# (and the rollback target) the highest version, so this tracks both.
entry=$(for f in "${BOOTROOT}"/loader/entries/*.conf; do
            [ -f "$f" ] || continue
            v=$(sed -n 's/^version //p' "$f" | head -1)
            printf '%s\t%s\n' "${v:-0}" "$f"
        done | sort -rn | head -1 | cut -f2)
[ -n "${entry:-}" ] || { echo "armada-bootimg-update: no BLS entry in ${BOOTROOT}/loader/entries" >&2; exit 1; }

linux=$(sed -n 's/^linux //p'   "${entry}" | head -1)
initrd=$(sed -n 's/^initrd //p' "${entry}" | head -1)
fdtdir=$(sed -n 's/^fdtdir //p' "${entry}" | head -1)
options=$(sed -n 's/^options //p' "${entry}" | head -1)

# BLS paths carry a /boot prefix (bootprefix=true); the files live on this fs.
kpath="${BOOTROOT}${linux#/boot}"
ipath="${BOOTROOT}${initrd#/boot}"
dpath="${BOOTROOT}${fdtdir#/boot}"

id=$(armada_bootimg_id "${linux}" "${initrd}" "${options}" "${DTB_LIST}" "${ARGS_FILE}")
if [ -f "${KERNEL_OUT}" ] && [ "$(cat "${STAMP}" 2>/dev/null || true)" = "${id}" ]; then
    echo "armada-bootimg-update: /KERNEL already current (${linux##*/})"
    exit 0
fi

# Fit the header-v0 512-byte cmdline: drop the serial console, put ostree first.
ostree_arg=""; rest=""
for t in ${options}; do
    case "${t}" in
        console=ttyS0) continue ;;
        ostree=*) ostree_arg="${t}" ;;
        *) rest="${rest} ${t}" ;;
    esac
done
cmdline="${ostree_arg}${rest}"

# Fail loud rather than ship a silently-truncated, unbootable /KERNEL that can
# only be recovered via fastboot. Limit is single-sourced (see bootimg-args).
if [ "${#cmdline}" -gt "${ARMADA_CMDLINE_MAX}" ]; then
    echo "armada-bootimg-update: assembled cmdline is ${#cmdline}B, over the ${ARMADA_CMDLINE_MAX}B limit" >&2
    exit 1
fi

work=$(mktemp -d)
trap 'rm -rf "${work}"' EXIT

# ROCKNIX ABL expects gzip(Image) with all supported DTBs appended; its model
# picker chooses among them at boot.
gzip -c "${kpath}" > "${work}/kernel.gz"
while read -r name; do
    [ -n "${name}" ] || continue
    dtb="${dpath}/qcom/${name}.dtb"
    [ -f "${dtb}" ] || { echo "armada-bootimg-update: missing DTB ${dtb}" >&2; exit 1; }
    cat "${dtb}" >> "${work}/kernel.gz"
done < "${DTB_LIST}"

python3 "${MKBOOTIMG}" \
    --kernel "${work}/kernel.gz" --ramdisk "${ipath}" \
    ${ARMADA_BOOTIMG_ARGS} --os_patch_level "$(date '+%Y-%m')" \
    --cmdline "${cmdline}" \
    -o "${work}/KERNEL"

# Atomic on the FAT ESP: rename can't leave a half-written /KERNEL.
cp -f "${work}/KERNEL" "${ESP}/.KERNEL.new"
sync "${ESP}/.KERNEL.new"
mv -f "${ESP}/.KERNEL.new" "${KERNEL_OUT}"
printf '%s' "${id}" > "${STAMP}"
sync

echo "armada-bootimg-update: wrote ${KERNEL_OUT} for ${linux##*/}"

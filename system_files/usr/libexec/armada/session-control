#!/usr/bin/bash
# zz- sorts after armada.conf so its Session= wins (User=/Relogin= stay there).
set -euo pipefail

case "${1:-}" in
    switch-desktop)  session=armada-niri.desktop ;;
    switch-gamemode) session=gamescope-session-steam.desktop ;;
    default-gamemode) session=gamescope-session-steam.desktop; default_only=1 ;;
    *) echo "usage: $0 {switch-desktop|switch-gamemode|default-gamemode}" >&2; exit 1 ;;
esac

logout_niri() {
    local user=armada
    local uid
    uid=$(id -u "${user}")
    local sock
    sock=$(find "/run/user/${uid}" -maxdepth 3 -type s -name '*.sock' -path '*niri*' 2>/dev/null | head -n1)
    if [[ -z "${sock}" ]]; then
        echo "niri socket not found for ${user}" >&2
        return 1
    fi
    sudo -u "${user}" NIRI_SOCKET="${sock}" XDG_RUNTIME_DIR="/run/user/${uid}" \
        niri msg action quit --skip-confirmation 2>/dev/null || true
}

printf '[Autologin]\nSession=%s\n' "${session}" > /etc/sddm.conf.d/zz-steamos-autologin.conf
systemctl reset-failed sddm.service 2>/dev/null || true

if [[ "${default_only:-0}" == "1" ]]; then
    exit 0
fi

if [[ ${1:-} == "switch-gamemode" ]] && logout_niri; then
    exit 0
fi

systemctl --no-block restart sddm.service

#!/usr/bin/env python3
import configparser
import os
import pathlib
import stat
import subprocess
import uuid


CONFIG_PATH = pathlib.Path("/boot/efi/armada.conf")
NM_CONNECTION = pathlib.Path("/etc/NetworkManager/system-connections/armada-bootstrap.nmconnection")


def read_config():
    if not CONFIG_PATH.is_file():
        return None, {}

    raw = CONFIG_PATH.read_text(encoding="utf-8-sig", errors="replace")
    parser = configparser.ConfigParser(interpolation=None)
    parser.optionxform = str.lower
    if any(line.strip().startswith("[") for line in raw.splitlines()):
        parser.read_string(raw)
    else:
        parser.read_string("[armada]\n" + raw)

    data = {}
    for section in parser.sections():
        for key, value in parser.items(section):
            data[f"{section.lower()}.{key.lower()}"] = value.strip()
            data[key.lower()] = value.strip()
    return CONFIG_PATH, data


def truthy(value):
    return value.strip().lower() in {"1", "true", "yes", "on", "enable", "enabled"}


def first(data, *keys):
    for key in keys:
        value = data.get(key)
        if value:
            return value
    return ""


def nm_escape(value):
    return value.replace("\\", "\\\\").replace("\n", "\\n")


def write_wifi(data):
    ssid = first(data, "wifi.ssid", "ssid")
    if not ssid:
        return False

    password = first(data, "wifi.password", "password")
    conn_uuid = str(uuid.uuid5(uuid.NAMESPACE_DNS, f"armada-boot:{ssid}"))
    lines = [
        "[connection]",
        "id=Armada Bootstrap Wi-Fi",
        f"uuid={conn_uuid}",
        "type=wifi",
        "autoconnect=true",
        "",
        "[wifi]",
        "mode=infrastructure",
        f"ssid={nm_escape(ssid)}",
        "",
    ]
    if password:
        lines.extend([
            "[wifi-security]",
            "key-mgmt=wpa-psk",
            f"psk={nm_escape(password)}",
            "",
        ])
    else:
        lines.extend([
            "[wifi-security]",
            "key-mgmt=none",
            "",
        ])
    lines.extend([
        "[ipv4]",
        "method=auto",
        "",
        "[ipv6]",
        "method=auto",
        "",
    ])

    NM_CONNECTION.parent.mkdir(parents=True, exist_ok=True)
    tmp = NM_CONNECTION.with_name(f".{NM_CONNECTION.name}.tmp")
    tmp.write_text("\n".join(lines), encoding="utf-8")
    os.chown(tmp, 0, 0)
    os.chmod(tmp, stat.S_IRUSR | stat.S_IWUSR)
    os.replace(tmp, NM_CONNECTION)
    return True


def configure_ssh(data):
    value = first(data, "ssh.enabled", "ssh")
    if not value:
        return None
    enabled = truthy(value)
    action = "enable" if enabled else "disable"
    subprocess.run(["systemctl", action, "--now", "sshd.service"], check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    return enabled


def main():
    path, data = read_config()
    if not data:
        return
    wifi = write_wifi(data)
    ssh = configure_ssh(data)
    print(f"Imported Armada bootstrap config from {path}: wifi={'yes' if wifi else 'no'} ssh={ssh}")


if __name__ == "__main__":
    main()

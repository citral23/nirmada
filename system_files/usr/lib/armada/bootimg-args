# ABL/header-v0 geometry, sourced by make-bootimg.sh + armada-bootimg-update so
# they can't drift (a mismatch ships an unbootable /KERNEL).
ARMADA_BOOTIMG_ARGS="--base 0x10000000 --pagesize 2048 --kernel_offset 0x00008000 --ramdisk_offset 0x06000000 --tags_offset 0x00000100 --header_version 0 --os_version 12.0.0"

# header-v0 also has extra_cmdline[1024], but the ABL may not read the overflow;
# cap at the first field until that's confirmed on-device.
ARMADA_CMDLINE_MAX=512

# Identity of a staged /KERNEL: kernel+initramfs+DTBs (via the boot-checksum
# paths), cmdline, and the DTB list + mkbootimg args (rootfs files outside that
# checksum). Regenerate iff one changes. Args: linux initrd options dtb_list args_file.
armada_bootimg_id() {
    { printf '%s\n%s\n%s\n' "$1" "$2" "$3"; cat "$4" "$5"; } | sha256sum | cut -d' ' -f1
}
